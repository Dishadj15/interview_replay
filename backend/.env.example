# Application
APP_NAME=Interview Replay
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite:///./interview_replay.db

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# OpenAI (optional — enables Whisper transcription and enhanced AI feedback)
OPENAI_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
